# Application settings
APP_NAME=voice-work-assistant
APP_ENV=development

# Server settings
HOST=127.0.0.1
PORT=8000

# Default browser resources
# Put the URL of the resource you want to open for the "Открой почту" command.
DEFAULT_MAIL_URL=https://example.com

# Template storage
# Path to the folder with .docx templates that use {{...}} placeholders.
TEMPLATES_DIR=./templates

# Output storage
# Path where generated documents are temporarily stored before download.
OUTPUT_DIR=./output

# Optional browser voice input notes
# Web Speech API is used in the browser; no API key is required here.
